{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/build-registry.mjs && node scripts/build-reference-quality.mjs && npm run build-reference-ast && node ../scripts/gen-llms-full.cjs && next dev -p 3335",
    "build": "node scripts/build-registry.mjs && node scripts/build-reference-quality.mjs && npm run build-reference-ast && node ../scripts/gen-llms-full.cjs && node scripts/build-embeddings.mjs && next build",
    "build-registry": "node scripts/build-registry.mjs",
    "build-reference-ast": "node --no-warnings --experimental-strip-types scripts/build-reference-ast.ts",
    "reference-ast:check": "node --no-warnings --experimental-strip-types scripts/build-reference-ast.ts --check",
    "quality:references": "node scripts/build-reference-quality.mjs",
    "quality:references:check": "node scripts/build-reference-quality.mjs --check",
    "reverify:queue": "node --no-warnings --experimental-strip-types scripts/build-reverify-queue.ts",
    "reverify:run": "node --no-warnings --experimental-strip-types scripts/run-reverify-task.ts",
    "reverify:batch": "node --no-warnings --experimental-strip-types scripts/run-reverify-batch.ts",
    "reverify:popular-plan": "node --no-warnings --experimental-strip-types scripts/build-popular-verification-plan.ts",
    "reverify:codex:check": "node --no-warnings --experimental-strip-types scripts/check-codex-reverify.ts",
    "reverify:hybrid:report": "node scripts/build-hybrid-reverify-report.mjs",
    "audit:context-depth": "node scripts/audit-reference-context-depth.mjs",
    "capture:reference": "node --no-warnings --experimental-strip-types scripts/capture-reference-evidence.ts",
    "capture:create-batch": "node --no-warnings --experimental-strip-types scripts/capture-create-batch.ts",
    "create:batch": "node --no-warnings --experimental-strip-types scripts/run-create-batch.ts",
    "capture:fixture:check": "node --no-warnings --experimental-strip-types scripts/check-reference-capture-fixture.ts",
    "check:reference-pipeline": "npm run build-registry && npm run quality:references:check && npm run build-reference-ast && npm run reference-ast:check && git diff --exit-code -- src/data/registry.generated.ts src/data/catalog-meta.generated.ts src/data/version.generated.ts",
    "check:reference-pipeline:reverify": "npm run build-registry && npm run quality:references && npm run build-reference-ast && npm run reference-ast:check",
    "build-embeddings": "node scripts/build-embeddings.mjs",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@base-ui/react": "^1.3.0",
    "@upstash/redis": "^1.37.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "lz-string": "^1.5.0",
    "mixpanel-browser": "^2.80.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@projectwallace/css-analyzer": "^9.9.0",
    "@tailwindcss/postcss": "^4",
    "@types/mixpanel-browser": "^2.60.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.1.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "husky": "^9.1.7",
    "playwright-core": "^1.61.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "postcss": "^8.5.15"
  }
}
