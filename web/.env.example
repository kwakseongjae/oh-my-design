# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Upstash Redis — used by /api/track and /api/leaderboard for per-reference
# popularity counters. Both vars must be set together; if either is missing,
# tracking gracefully no-ops.
#
# Option A: Vercel Marketplace > Upstash integration (recommended for deploy).
# Marketplace injects these names automatically, prefixed with the project label.
OMD_KV_REST_API_URL=
OMD_KV_REST_API_TOKEN=
#
# Option B: Direct upstash.com REST credentials (used as fallback if OMD_* unset).
# Pick this path for local dev if you're not using Vercel's integration.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Anthropic API key — used by /api/font-playground/match (dev-only Haiku
# font matcher). If unset, the Stage 2 matcher silently falls back to the
# deterministic keyword rules in match-intent.ts.
OMD_ANTHROPIC_API_KEY=
