# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Upstash Redis (Vercel Marketplace > Upstash, or upstash.com console)
# Used by /api/track and /api/leaderboard for per-reference popularity counters.
# Both vars must be set together; if either is missing, tracking gracefully no-ops.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
