{
  "name": "oh-my-design-mcp",
  "version": "0.1.0",
  "description": "Drop-in MCP server exposing 107 brand design systems (DESIGN.md) as resources + 3 tools. Zero AI calls, zero config, fully offline.",
  "type": "module",
  "bin": {
    "oh-my-design-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "data",
    "README.md"
  ],
  "scripts": {
    "sync-data": "node scripts/sync-data.mjs",
    "build": "npm run sync-data && tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "design-system",
    "design-md",
    "claude",
    "cursor",
    "cline",
    "continue",
    "codex",
    "oh-my-design"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kwakseongjae/oh-my-design",
    "directory": "packages/mcp"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
