{
  "name": "oh-my-design",
  "version": "0.1.0",
  "description": "Interactive CLI to generate DESIGN.md files for AI coding agents",
  "type": "module",
  "bin": {
    "oh-my-design": "./dist/bin/oh-my-design.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup && cp -r src/templates dist/templates",
    "dev": "tsup --watch",
    "start": "node dist/bin/oh-my-design.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "design-system",
    "design-md",
    "shadcn",
    "cli",
    "ai-agent",
    "google-stitch",
    "design-tokens",
    "vibe-coding"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kwakseongjae/oh-my-design"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "commander": "^13.1.0",
    "handlebars": "^4.7.8",
    "picocolors": "^1.1.1",
    "shadcn": "^4.2.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
